# =========================================================================
# KONFIGURASI WHATSAPP BOT - EXPERIMENTAL-BELL
# =========================================================================

# --- 1. E2B Sandbox ---
# E2B_API_KEY diperlukan untuk menjalankan fitur E2B Sandbox (eksekusi kode Python aman).
# Cara mendapatkan API Key E2B:
# 1. Buka website https://e2b.dev dan login / daftar akun.
# 2. Pergi ke dashboard dan masuk ke menu "API Keys" (https://e2b.dev/dashboard?tab=keys).
# 3. Buat API key baru, salin, lalu tempel di bawah ini (ganti "your_e2b_api_key").
E2B_API_KEY=e2b_756506836bd17e3da1d8d09d3479d05c460704ac

# --- 2. Virtual File System (VFS) ---
# Fitur VFS (Virtual File System) berjalan secara lokal dan otomatis tanpa memerlukan API key eksternal!
# Seluruh file VFS dari setiap user akan disimpan secara terisolasi di dalam direktori lokal:
# ./toolkit/db/vfs/<nomor_whatsapp_user>/
# Anda tidak perlu mengonfigurasi atau menambahkan key apa pun untuk fitur VFS ini di dalam file .env.
